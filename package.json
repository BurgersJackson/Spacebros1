{
  "name": "spacebros",
  "version": "0.1.0",
  "private": true,
  "description": "Neon Space Cave (Electron wrapper)",
  "main": "electron/main.js",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "start:dev": "node scripts/start-electron.js --devtools",
    "start:smoke": "node scripts/start-electron.js --smoke",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "vitest": "^4.0.17"
  },
  "build": {
    "appId": "com.spacebros.neonspacecave",
    "productName": "Neon Space Cave",
    "files": [
      "package.json",
      "electron/**/*",
      "assets/**/*",
      "src/**/*",
      "index.html",
      "node_modules/phaser/dist/phaser.min.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Game",
      "description": "A 2D space shooter with neon graphics and upgrade systems"
    }
  }
}
